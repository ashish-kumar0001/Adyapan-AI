generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String?
  githubId   String?  @unique @map("github_id")
  avatarUrl  String?  @map("avatar_url")
  role       Role     @default(USER)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  profile    Profile?

  // Payment / Subscription Relations
  plan                String   @default("free")
  razorpayCustomerId  String?  @map("razorpay_customer_id")
  razorpaySubscriptionId String? @map("razorpay_subscription_id")
  subscriptionStatus  String?  @map("subscription_status")
  subscriptionEnd     DateTime? @map("subscription_end")
  payments            Payment[]

  @@map("users")
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  college           String?
  branch            String?
  phone             String?
  year              String?
  careerGoal        String?  @map("career_goal")
  skills            String[] @default([])
  linkedin          String?
  github            String?
  resumeUrl         String?  @map("resume_url")
  resumeName        String?  @map("resume_name")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  aboutMe           String?  @map("about_me")
  careerObjective   String?  @map("career_objective")
  degree            String?
  graduationYear    String?  @map("graduation_year")
  interestedDomains String[] @default([]) @map("interested_domains")
  location          String?
  portfolio         String?
  targetRole        String?  @map("target_role")
  username          String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Payment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  orderId   String   @unique @map("order_id")
  paymentId String?  @unique @map("payment_id")
  signature String?  @map("signature")
  amount    Int
  currency  String   @default("INR")
  plan      String
  status    String   @default("created")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model BlacklistedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blacklisted_tokens")
}

enum Role {
  USER
  ADMIN
}

model CommunityFollow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([followerId])
  @@index([followingId])
  @@unique([followerId, followingId])
  @@map("community_follows")
}

model CommunityMessage {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([senderId])
  @@index([receiverId])
  @@map("community_messages")
}

model CommunityActivity {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  detail    String   @default("")
  xp        Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("community_activities")
}

model CommunityAchievement {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  description String
  icon        String   @default("trophy")
  xp          Int      @default(0)
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  @@index([userId])
  @@map("community_achievements")
}

model CommunityProject {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  description String
  techStack   String[]
  url         String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("community_projects")
}