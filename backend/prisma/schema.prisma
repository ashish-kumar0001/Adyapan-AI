generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  profile   Profile?

  // Payment / Subscription Relations
  plan                String   @default("free")
  razorpayCustomerId  String?  @map("razorpay_customer_id")
  razorpaySubscriptionId String? @map("razorpay_subscription_id")
  subscriptionStatus  String?  @map("subscription_status")
  subscriptionEnd     DateTime? @map("subscription_end")
  payments            Payment[]

  @@map("users")
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  college           String?
  branch            String?
  phone             String?
  year              String?
  careerGoal        String?  @map("career_goal")
  skills            String[] @default([])
  linkedin          String?
  github            String?
  resumeUrl         String?  @map("resume_url")
  resumeName        String?  @map("resume_name")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  aboutMe           String?  @map("about_me")
  careerObjective   String?  @map("career_objective")
  degree            String?
  graduationYear    String?  @map("graduation_year")
  interestedDomains String[] @default([]) @map("interested_domains")
  location          String?
  portfolio         String?
  targetRole        String?  @map("target_role")
  username          String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Payment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  orderId   String   @unique @map("order_id")
  paymentId String?  @unique @map("payment_id")
  signature String?  @map("signature")
  amount    Int
  currency  String   @default("INR")
  plan      String
  status    String   @default("created")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("payments")
}

model BlacklistedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blacklisted_tokens")
}

enum Role {
  USER
  ADMIN
}

model CodingQuestion {
  id                  String   @id @default(cuid())
  externalId          String   @unique @map("external_id")
  source              String
  title               String
  problemUrl          String   @map("problem_url")
  difficulty          String
  rating              Int?
  topic               String
  tagsJson            Json     @map("tags_json")
  placementImportance Boolean  @default(false) @map("placement_importance")
  interviewImportance Boolean  @default(false) @map("interview_importance")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  aiAnalyses          QuestionAIAnalysis[]
  dailyChallenges     DailyChallenge[]

  @@map("coding_questions")
}

model UserQuestionProgress {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  questionId     String   @map("question_id")
  status         String   @default("unsolved")
  viewed         Boolean  @default(false)
  attempted      Boolean  @default(false)
  solved         Boolean  @default(false)
  bookmarked     Boolean  @default(false)
  timeSpent      Int      @default(0) @map("time_spent")
  runCount       Int      @default(0) @map("run_count")
  successfulRuns Int      @default(0) @map("successful_runs")
  failedRuns     Int      @default(0) @map("failed_runs")
  languageUsage  Json     @default("{}") @map("language_usage")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, questionId])
  @@map("user_question_progress")
}

model QuestionAIAnalysis {
  id                 String         @id @default(cuid())
  questionId         String         @map("question_id")
  explanationJson    Json           @map("explanation_json")
  generatedByModel   String         @map("generated_by_model")
  generatedAt        DateTime       @default(now()) @map("generated_at")
  question           CodingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_ai_analysis")
}

model DailyChallenge {
  id            String         @id @default(cuid())
  questionId    String         @map("question_id")
  challengeDate DateTime       @map("challenge_date")
  createdAt     DateTime       @default(now()) @map("created_at")
  question      CodingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("daily_challenges")
}

model CareerRoadmap {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  targetRole        String   @map("target_role")
  timeline          String   @default("90 Days")
  readinessScore    Int      @default(0) @map("readiness_score")
  technicalScore    Int      @default(0) @map("technical_score")
  resumeScore       Int      @default(0) @map("resume_score")
  interviewScore    Int      @default(0) @map("interview_score")
  placementScore    Int      @default(0) @map("placement_score")
  recruiterScore    Int      @default(0) @map("recruiter_score")
  roadmapJson       Json     @map("roadmap_json")
  weeklyPlanJson    Json     @map("weekly_plan_json")
  gapAnalysisJson   Json     @map("gap_analysis_json")
  skillMapJson      Json     @map("skill_map_json")
  projectRecsJson   Json     @map("project_recs_json")
  certRecsJson      Json     @map("cert_recs_json")
  marketInsightsJson Json    @map("market_insights_json")
  coachFeedbackJson Json     @map("coach_feedback_json")
  milestonesJson    Json     @map("milestones_json")
  versionNumber     Int      @default(1) @map("version_number")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tasks             CareerTask[]

  @@index([userId])
  @@index([createdAt])
  @@map("career_roadmaps")
}

model CareerTask {
  id              String        @id @default(cuid())
  roadmapId       String        @map("roadmap_id")
  userId          String        @map("user_id")
  title           String
  description     String        @default("")
  category        String        @default("learning")
  priority        String        @default("Medium")
  status          String        @default("not_started")
  estimatedHours  Float         @default(1) @map("estimated_hours")
  impactScore     Int           @default(50) @map("impact_score")
  dueDate         DateTime?     @map("due_date")
  completedAt     DateTime?     @map("completed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  roadmap         CareerRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@index([userId])
  @@index([status])
  @@map("career_tasks")
}

model CareerDashboardSnapshot {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  overallReadiness  Int      @map("overall_readiness")
  codingScore       Int      @map("coding_score")
  learningScore     Int      @map("learning_score")
  resumeScore       Int      @map("resume_score")
  atsScore          Int      @map("ats_score")
  linkedinScore     Int      @map("linkedin_score")
  dashboardJson     Json     @map("dashboard_json")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("career_dashboard_snapshots")
}

model ResearchPaper {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  title         String
  domain        String   @default("General Science")
  abstract      String   @db.Text
  keywords      String[] @default([])
  contentJson   Json     @map("content_json")
  status        String   @default("DRAFT")
  template      String   @default("IEEE")
  citationStyle String   @default("IEEE") @map("citation_style")
  wordCount     Int      @default(0) @map("word_count")
  pageCount     Int      @default(1) @map("page_count")
  readingTime   Int      @default(1) @map("reading_time")
  isFavorite    Boolean  @default(false) @map("is_favorite")
  authors       Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("research_papers")
}

model PaperDraft {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  domain      String   @default("Computer Science")
  currentStep Int      @default(1) @map("current_step")
  configJson  Json     @map("config_json")
  contentJson Json     @map("content_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([updatedAt])
  @@map("paper_drafts")
}

model PaperExport {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  paperId     String?  @map("paper_id")
  title       String
  format      String   // pdf, docx, latex, markdown
  template    String   @default("IEEE")
  downloadUrl String?  @map("download_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("paper_exports")
}

model PaperUpload {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  filename      String
  fileSize      Int      @map("file_size")
  parsedText    String   @db.Text @map("parsed_text")
  extractedMeta Json     @map("extracted_meta")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("paper_uploads")
}

model AIResearchLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  paperId    String?  @map("paper_id")
  action     String   // generate_paper, generate_section, enhance, diagram, etc.
  tokensUsed Int      @default(0) @map("tokens_used")
  durationMs Int      @default(0) @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("ai_research_logs")
}

model CommunityFollow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([followerId])
  @@index([followingId])
  @@unique([followerId, followingId])
  @@map("community_follows")
}

model CommunityMessage {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([senderId])
  @@index([receiverId])
  @@map("community_messages")
}

model CommunityActivity {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  detail    String   @default("")
  xp        Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("community_activities")
}

model CommunityAchievement {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  description String
  icon        String   @default("trophy")
  xp          Int      @default(0)
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  @@index([userId])
  @@map("community_achievements")
}

model CommunityProject {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  description String
  techStack   String[]
  url         String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("community_projects")
}



